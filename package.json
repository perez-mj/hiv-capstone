{
  "name": "note-archiver",
  "version": "1.0.0",
  "scripts": {
    "start-backend": "npm run dev --prefix backend",
    "start-frontend": "npm run dev --prefix frontend",
    "start": "run-p start-backend start-frontend",
    "blockchain:start": "node backend/scripts/start-blockchain.js",
    "blockchain:stop": "node backend/scripts/stop-blockchain.js",
    "blockchain:restart": "node backend/scripts/restart-blockchain.js",
    "blockchain:status": "node backend/scripts/blockchain-status.js",
    "blockchain:setup": "node backend/scripts/setup-multichain.js",
    "blockchain:reset": "node backend/scripts/reset-multichain.js",
    "blockchain:logs": "tail -f ~/.multichain/omph_hiv_chain/debug.log"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "npm-run-all": "^4.1.5"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "vue-toastification": "^2.0.0-rc.5"
  }
}
